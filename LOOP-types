4. Write a C program to print all even numbers between 1 to 100.
#include<stdio.h>
int main()
{
    int i;
    for(i=1; i<=100; i++)
    {
        if(i%2==1)
        {
            printf(" %d is odd \n",i);
        }
    }

    printf("while loop \n");
    int b=1;
    while(b<=100)
    {
        if(b%2==1)
        {
            printf(" %d is odd",b);
        }
        b++;
    }

    printf(" do while loop\n");
    int c=1;
    do
    {
        if(c%2==1)
        {
            printf(" %d \n",c);
        }
        c++;
    }
    while(c<=100);
    return 0;
}

