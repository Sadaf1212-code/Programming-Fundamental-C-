6. Write a C program to find sum of all odd numbers between 1 to n.
#include <stdio.h>
int main()
{
    int i, s = 0;
    for (i = 1; i <= 100; i++)
    {
        if (i % 2 != 0)
        {
            s = s + i;
        }
    }
    printf("Sum of odd numbers (for loop) = %d\n", s);

    int b = 1, s1 = 0;
    while (b <= 100)
    {
        if (b % 2 != 0)
        {
            s1 = s1 + b;
        }
        b++;
    }
    printf("Sum of odd numbers (while loop) = %d\n", s1);

    int c = 1, s2 = 0;
    do
    {
        if (c % 2 != 0)
        {
            s2 = s2 + c;
        }
        c++;
    }
    while (c <= 100);
    printf("Sum of odd numbers (do...while loop) = %d\n", s2);

    return 0;
}

